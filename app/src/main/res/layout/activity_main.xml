<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PalGate Opener"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.05"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/tv_phone"
            android:textColor="#666666"
            android:textSize="13sp"
            android:layout_marginBottom="32dp"/>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/iv_status_dot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/dot_green"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Starting..."
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_last_event"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last: None"
                android:textColor="#888888"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Gate Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GATES"
                android:textColor="#444444"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tv_gate1_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tv_gate2_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- Manual Buttons -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MANUAL OVERRIDE"
            android:textColor="#444444"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <Button
                android:id="@+id/btn_open_gate1"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Open Gate 1"
                android:textColor="#000000"
                android:backgroundTint="#00C896"
                android:textAllCaps="false"
                android:textSize="15sp"/>

            <Button
                android:id="@+id/btn_open_gate2"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Open Gate 2"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1E1E1E"
                android:textAllCaps="false"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- Settings Button -->
        <Button
            android:id="@+id/btn_settings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="⚙ Settings"
            android:textColor="#888888"
            android:backgroundTint="#111111"
            android:textAllCaps="false"
            android:textSize="15sp"/>

    </LinearLayout>
</ScrollView>
