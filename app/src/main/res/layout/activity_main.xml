<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="פותח שערים"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_linked_as"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="13sp"
            android:layout_marginBottom="28dp"/>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/iv_dot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/dot_red"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="מאתחל..."
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_last_event"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="אחרון: אין"
                android:textColor="#666666"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Link Button -->
        <Button
            android:id="@+id/btn_link"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="קשר חשבון PalGate"
            android:textColor="#000000"
            android:backgroundTint="#00C896"
            android:textAllCaps="false"
            android:textSize="16sp"/>

        <!-- Gate Buttons -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="פתיחה ידנית"
            android:textColor="#444444"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btn_gate1"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="פתח שער 1"
                android:textColor="#000000"
                android:backgroundTint="#00C896"
                android:textAllCaps="false"
                android:enabled="false"/>

            <Button
                android:id="@+id/btn_gate2"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="פתח שער 2"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1E1E1E"
                android:textAllCaps="false"
                android:enabled="false"/>
        </LinearLayout>

        <!-- Settings -->
        <Button
            android:id="@+id/btn_settings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="⚙ הגדרות"
            android:textColor="#666666"
            android:backgroundTint="#111111"
            android:textAllCaps="false"
            android:textSize="14sp"/>

    </LinearLayout>
</ScrollView>
