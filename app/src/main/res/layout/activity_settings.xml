<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- SERVICE -->
        <TextView style="@style/SectionLabel" android:text="כללי"/>

        <LinearLayout style="@style/RowLayout">
            <TextView style="@style/RowLabel" android:text="שירות רקע פעיל"/>
            <Switch android:id="@+id/sw_service" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- GATES -->
        <TextView style="@style/SectionLabel" android:text="שערים"/>

        <LinearLayout style="@style/RowLayout">
            <TextView style="@style/RowLabel" android:text="שער 1 פעיל (כניסה ראשית)"/>
            <Switch android:id="@+id/sw_gate1" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout style="@style/RowLayout">
            <TextView style="@style/RowLabel" android:text="שער 2 פעיל"/>
            <Switch android:id="@+id/sw_gate2" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- VEHICLE 1 -->
        <TextView style="@style/SectionLabel" android:text="רכב ראשי"/>

        <TextView style="@style/FieldLabel" android:text="Bluetooth נבחר:"/>
        <TextView
            android:id="@+id/tv_v1_bt_current"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00C896"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_pick_bt"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="בחר רכב מרשימת Bluetooth"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1E1E1E"
            android:textAllCaps="false"
            android:layout_marginBottom="16dp"/>

        <!-- VEHICLE 2 -->
        <LinearLayout style="@style/RowLayout">
            <TextView style="@style/SectionLabel" android:layout_width="0dp"
                android:layout_weight="1" android:text="רכב שני" android:layout_marginBottom="0dp"/>
            <Switch android:id="@+id/sw_v2" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/layout_v2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView style="@style/FieldLabel" android:text="Bluetooth רכב שני:"/>
            <EditText android:id="@+id/et_v2_bt" style="@style/FieldInput" android:hint="שם Bluetooth"/>

            <Button
                android:id="@+id/btn_pick_bt2"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="בחר רכב שני מרשימת Bluetooth"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1E1E1E"
                android:textAllCaps="false"
                android:layout_marginBottom="16dp"/>
        </LinearLayout>

        <!-- NETWORK -->
        <TextView style="@style/SectionLabel" android:text="רשת WiFi"/>
        <TextView style="@style/FieldLabel" android:text="שם רשת חניון (SSID):"/>
        <EditText android:id="@+id/et_wifi" style="@style/FieldInput" android:hint="KingShaul6"/>

        <!-- TRIGGER SETTINGS -->
        <TextView style="@style/SectionLabel" android:text="הגדרות טריגר"/>

        <TextView style="@style/FieldLabel" android:text="רדיוס כניסה (מטרים):"/>
        <EditText android:id="@+id/et_radius" style="@style/FieldInput"
            android:hint="80" android:inputType="number"/>

        <TextView style="@style/FieldLabel" android:text="מהירות מינימלית לכניסה (קמ&#34;ש):"/>
        <EditText android:id="@+id/et_enter_speed" style="@style/FieldInput"
            android:hint="10" android:inputType="number"/>

        <TextView style="@style/FieldLabel" android:text="מהירות מינימלית ליציאה (קמ&#34;ש):"/>
        <EditText android:id="@+id/et_exit_speed" style="@style/FieldInput"
            android:hint="10" android:inputType="number"/>

        <TextView style="@style/FieldLabel" android:text="זמן המתנה בין פתיחות (שניות):"/>
        <EditText android:id="@+id/et_cooldown" style="@style/FieldInput"
            android:hint="60" android:inputType="number"/>

        <!-- Save -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="שמור הגדרות"
            android:textColor="#000000"
            android:backgroundTint="#00C896"
            android:textAllCaps="false"
            android:textSize="16sp"/>

    </LinearLayout>
</ScrollView>
