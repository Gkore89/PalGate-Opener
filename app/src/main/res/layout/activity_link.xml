<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="חיבור חשבון PalGate"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:textAlignment="center"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"/>

        <!-- QR Code -->
        <ImageView
            android:id="@+id/iv_qr"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_gravity="center"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:layout_marginBottom="12dp"
            android:scaleType="fitCenter"/>

        <!-- Status -->
        <TextView
            android:id="@+id/tv_link_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:textAlignment="center"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <!-- Share button -->
        <Button
            android:id="@+id/btn_share"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="שלח QR למחשב / טאבלט"
            android:textColor="#000000"
            android:backgroundTint="#00C896"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <!-- Waiting instructions - RTL fixed -->
        <LinearLayout
            android:id="@+id/layout_waiting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="שלבי החיבור:"
                android:textColor="#00C896"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:textAlignment="textEnd"
                android:gravity="end"
                android:layout_marginBottom="12dp"/>

            <!-- Step 1 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="28dp" android:layout_height="28dp"
                    android:text="1" android:textColor="#0D0D0D" android:textSize="14sp"
                    android:fontFamily="sans-serif-bold" android:gravity="center"
                    android:background="@drawable/dot_green" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="לחץ שלח QR ושלח את התמונה לעצמך (וואטסאפ / מייל)"
                    android:textColor="#CCCCCC" android:textSize="13sp"
                    android:textAlignment="textEnd" android:gravity="end"/>
            </LinearLayout>

            <!-- Step 2 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="28dp" android:layout_height="28dp"
                    android:text="2" android:textColor="#0D0D0D" android:textSize="14sp"
                    android:fontFamily="sans-serif-bold" android:gravity="center"
                    android:background="@drawable/dot_green" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="פתח את התמונה במחשב, טאבלט, או טלוויזיה חכמה"
                    android:textColor="#CCCCCC" android:textSize="13sp"
                    android:textAlignment="textEnd" android:gravity="end"/>
            </LinearLayout>

            <!-- Step 3 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="28dp" android:layout_height="28dp"
                    android:text="3" android:textColor="#0D0D0D" android:textSize="14sp"
                    android:fontFamily="sans-serif-bold" android:gravity="center"
                    android:background="@drawable/dot_green" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="פתח את אפליקציית PalGate על הטלפון הזה"
                    android:textColor="#CCCCCC" android:textSize="13sp"
                    android:textAlignment="textEnd" android:gravity="end"/>
            </LinearLayout>

            <!-- Step 4 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="28dp" android:layout_height="28dp"
                    android:text="4" android:textColor="#0D0D0D" android:textSize="14sp"
                    android:fontFamily="sans-serif-bold" android:gravity="center"
                    android:background="@drawable/dot_green" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="☰ ← מכשירים מקושרים ← קשר מכשיר"
                    android:textColor="#CCCCCC" android:textSize="13sp"
                    android:textAlignment="textEnd" android:gravity="end"/>
            </LinearLayout>

            <!-- Step 5 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="28dp" android:layout_height="28dp"
                    android:text="5" android:textColor="#0D0D0D" android:textSize="14sp"
                    android:fontFamily="sans-serif-bold" android:gravity="center"
                    android:background="@drawable/dot_green" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="סרוק את קוד ה-QR שמוצג על המסך האחר"
                    android:textColor="#00C896" android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:textAlignment="textEnd" android:gravity="end"/>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="החיבור יאושר אוטומטית לאחר הסריקה ✓"
                android:textColor="#666666"
                android:textSize="12sp"
                android:textAlignment="center"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Success -->
        <LinearLayout
            android:id="@+id/layout_success"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textColor="#00C896"
                android:textSize="48sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="החיבור הצליח!"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:textAlignment="center"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_success_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#00C896"
                android:textSize="14sp"
                android:textAlignment="center"
                android:gravity="center"/>

            <Button
                android:id="@+id/btn_done"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="סגור"
                android:textColor="#000000"
                android:backgroundTint="#00C896"
                android:textAllCaps="false"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_retry"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="נסה שוב"
            android:textColor="#000000"
            android:backgroundTint="#00C896"
            android:textAllCaps="false"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_back"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="חזור"
            android:textColor="#CCCCCC"
            android:backgroundTint="#2A2A2A"
            android:textAllCaps="false"/>

    </LinearLayout>
</ScrollView>
