<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">#111111</item>
        <item name="colorPrimaryDark">#000000</item>
        <item name="colorAccent">#00C896</item>
        <item name="android:windowBackground">#0D0D0D</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#CCCCCC</item>
        <item name="android:layoutDirection">rtl</item>
        <item name="alertDialogTheme">@style/LightDialog</item>
        <item name="android:alertDialogTheme">@style/LightDialog</item>
    </style>

    <style name="LightDialog" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="colorAccent">#00C896</item>
        <item name="android:textColorPrimary">#111111</item>
        <item name="android:textColor">#111111</item>
        <item name="android:background">#FFFFFF</item>
    </style>

    <style name="SectionLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#AAAAAA</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:gravity">end</item>
        <item name="android:textAlignment">textEnd</item>
    </style>

    <style name="FieldLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#CCCCCC</item>
        <item name="android:textSize">13sp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:gravity">end</item>
        <item name="android:textAlignment">textEnd</item>
    </style>

    <style name="FieldInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorHint">#555555</item>
        <item name="android:textSize">14sp</item>
        <item name="android:background">@drawable/input_bg</item>
        <item name="android:padding">12dp</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:gravity">end</item>
        <item name="android:textAlignment">textEnd</item>
    </style>

    <style name="RowLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <style name="RowLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">#DDDDDD</item>
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">end</item>
        <item name="android:textAlignment">textEnd</item>
    </style>

</resources>
